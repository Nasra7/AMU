# Copy this file to .env and fill in real values. Never commit the real .env.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-string

# ElevenLabs (text-to-speech) - https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_DEFAULT_MODEL_ID=eleven_multilingual_v2

# Optional: per age/gender voice overrides used in conversations/services/txt_to_speech.py
ELEVENLABS_MALE_CHILD_VOICE=
ELEVENLABS_MALE_TEEN_VOICE=
ELEVENLABS_MALE_YOUNG_ADULT_VOICE=
ELEVENLABS_MALE_ADULT_VOICE=
ELEVENLABS_MALE_SENIOR_VOICE=
ELEVENLABS_FEMALE_CHILD_VOICE=
ELEVENLABS_FEMALE_TEEN_VOICE=
ELEVENLABS_FEMALE_YOUNG_ADULT_VOICE=
ELEVENLABS_FEMALE_ADULT_VOICE=
ELEVENLABS_FEMALE_SENIOR_VOICE=

# OpenAI (secondary LLM provider, fallback to Ollama)
OPENAI_API_KEY=
